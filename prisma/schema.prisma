generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Performances {
  PerformanceID   Int       @id @default(autoincrement())
  PlayerID        Int?
  ScoutID         Int?
  MatchDate       DateTime  @db.Date
  Goals           Int?      @default(0)
  Assists         Int?      @default(0)
  Passes          Int?      @default(0)
  Rating          Float?
  Comments        String?   @db.Text
  CalculatedScore Float?
  CreatedAt       DateTime? @default(now())
  Players         Players?  @relation(fields: [PlayerID], references: [PlayerID], onDelete: NoAction, onUpdate: NoAction)
  Users           Users?    @relation(fields: [ScoutID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
}

model Players {
  PlayerID         Int                @id @default(autoincrement())
  Name             String             @db.VarChar(100)
  Age              Int?
  Position         String             @db.VarChar(30)
  Club             String?            @db.VarChar(100)
  Height           Float?
  Weight           Float?
  CreatedByScoutID Int?
  CreatedAt        DateTime?          @default(now())
  UpdatedAt        DateTime?          @default(now())
  Performances     Performances[]
  Users            Users?             @relation(fields: [CreatedByScoutID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
  Rankings         Rankings[]
  Reports          Reports[]
  ScoutNotes       ScoutNotes[]
  WatchListPlayers WatchListPlayers[]
}

model Rankings {
  RankingID     Int       @id @default(autoincrement())
  PlayerID      Int?
  Position      String    @db.VarChar(30)
  Rank          Int
  GeneratedDate DateTime? @default(now())
  Players       Players?  @relation(fields: [PlayerID], references: [PlayerID], onDelete: NoAction, onUpdate: NoAction)
}

model Reports {
  ReportID          Int       @id @default(autoincrement())
  GeneratedByUserID Int?
  PlayerID          Int?
  GeneratedDate     DateTime? @default(now())
  Format            String    @db.VarChar(10)
  Users             Users?    @relation(fields: [GeneratedByUserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
  Players           Players?  @relation(fields: [PlayerID], references: [PlayerID], onDelete: NoAction, onUpdate: NoAction)
}

model ScoutNotes {
  NoteID    Int       @id @default(autoincrement())
  PlayerID  Int?
  ScoutID   Int?
  NoteText  String    @db.Text
  CreatedAt DateTime? @default(now())
  Players   Players?  @relation(fields: [PlayerID], references: [PlayerID], onDelete: NoAction, onUpdate: NoAction)
  Users     Users?    @relation(fields: [ScoutID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
}

model Users {
  UserID       Int            @id @default(autoincrement())
  Name         String         @db.VarChar(100)
  Email        String         @unique @db.VarChar(150)
  PasswordHash String         @db.VarChar(256)
  Role         String         @db.VarChar(20)
  CreatedAt    DateTime?      @default(now())
  UpdatedAt    DateTime?      @default(now())
  Performances Performances[]
  Players      Players[]
  Reports      Reports[]
  ScoutNotes   ScoutNotes[]
  WatchLists   WatchLists[]
}

model WatchListPlayers {
  WatchListID Int
  PlayerID    Int
  AddedAt     DateTime?  @default(now())
  Players     Players    @relation(fields: [PlayerID], references: [PlayerID], onUpdate: NoAction)
  WatchLists  WatchLists @relation(fields: [WatchListID], references: [WatchListID], onUpdate: NoAction)

  @@id([WatchListID, PlayerID])
}

model WatchLists {
  WatchListID      Int                @id @default(autoincrement())
  ListName         String             @db.VarChar(100)
  OwnerUserID      Int?
  CreatedAt        DateTime?          @default(now())
  WatchListPlayers WatchListPlayers[]
  Users            Users?             @relation(fields: [OwnerUserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
}
